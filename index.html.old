<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FAHPi — Filipino Australian Health Professionals Inc.</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=Playfair+Display:wght@400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#0a2240;--navy-light:#1e4a78;
  --gold:#c9962a;--gold-light:#e8b84b;--gold-pale:#fdf3df;
  --cream:#f8f6f1;--white:#fff;
  --text:#111827;--muted:#6b7280;--light:#9ca3af;
  --border:rgba(0,0,0,0.09);--border-strong:rgba(0,0,0,0.15);
  --red-ph:#d62d20;--blue-ph:#0038a8;
  --r:8px;--rl:14px;
  --green:#2e7d52;--green-light:#3a9e68;--green-pale:#e8f5ee;--green-mid:#1a5c3a;
}
html{scroll-behavior:smooth}
body{font-family:"DM Sans",system-ui,sans-serif;font-size:16px;line-height:1.65;color:var(--text);background:var(--cream)}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:var(--navy);display:flex;align-items:center;justify-content:space-between;padding:0 2.5rem;height:72px;gap:2rem}
.nav-logo{display:flex;align-items:center;gap:12px;text-decoration:none;flex-shrink:0}
.nav-logo img{height:48px;width:auto}
.nav-logo-text{color:#fff;font-size:14px;font-weight:500;line-height:1.3}
.nav-logo-text span{color:var(--gold-light);font-size:11px;display:block;font-weight:400}
.nav-links{display:flex;align-items:center;gap:4px;list-style:none}
.nav-links a{color:rgba(255,255,255,.75);text-decoration:none;font-size:13.5px;padding:6px 12px;border-radius:var(--r);transition:.15s}
.nav-links a:hover{color:#fff;background:rgba(255,255,255,.08)}
.nav-links a.active{color:var(--gold-light)}
.nav-cta{background:var(--gold)!important;color:var(--navy)!important;font-weight:600!important}
.nav-cta:hover{background:var(--gold-light)!important}

/* PAGES */
.page{display:none}
.page.active{display:block}

/* HERO */
.hero{background:var(--navy);color:#fff;padding:5rem 2.5rem;position:relative;overflow:hidden}
.hero::before{content:"";position:absolute;inset:0;background:radial-gradient(ellipse at 70% 50%,rgba(201,150,42,.12),transparent 60%);pointer-events:none}
.hero-stripe{position:absolute;top:0;right:0;width:4px;height:100%;background:linear-gradient(to bottom,var(--red-ph) 50%,var(--blue-ph) 50%)}
.hero-inner{max-width:820px;margin:0 auto;position:relative}
.eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:12px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;color:var(--gold-light);margin-bottom:1.25rem}
.eyebrow::before{content:"";width:24px;height:1.5px;background:var(--gold);display:inline-block}
.hero h1{font-family:"Playfair Display",serif;font-size:clamp(2.2rem,5vw,3.4rem);font-weight:400;line-height:1.18;margin-bottom:1.5rem}
.hero h1 em{font-style:italic;color:var(--gold-light)}
.hero-lead{font-size:1.05rem;color:rgba(255,255,255,.72);max-width:600px;line-height:1.75;margin-bottom:2.5rem}
.hero-actions{display:flex;gap:12px;flex-wrap:wrap}
.btn{display:inline-block;padding:12px 24px;border-radius:var(--r);border:none;cursor:pointer;font-family:"DM Sans",sans-serif;font-size:14px;font-weight:600;text-decoration:none;transition:.15s}
.btn-gold{background:var(--gold);color:var(--navy)}
.btn-gold:hover{background:var(--gold-light)}
.btn-outline{background:transparent;color:rgba(255,255,255,.85);border:1px solid rgba(255,255,255,.22);padding:11px 24px}
.btn-outline:hover{border-color:rgba(255,255,255,.5);color:#fff}

/* STATS BAR */
.stats-bar{background:var(--white);border-bottom:1px solid var(--border)}
.stats-inner{max-width:900px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr)}
.stat-item{padding:1.75rem 2rem;border-right:1px solid var(--border);text-align:center}
.stat-item:last-child{border-right:none}
.stat-num{font-family:"Playfair Display",serif;font-size:2rem;color:var(--navy);line-height:1;margin-bottom:4px}
.stat-label{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.07em}

/* SECTIONS */
section{padding:5rem 2.5rem}
.inner{max-width:900px;margin:0 auto}
.sec-eye{font-size:11.5px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-bottom:.75rem}
.sec-eye.green{color:var(--green)}
.sec-head{font-family:"Playfair Display",serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:400;color:var(--navy);line-height:1.2;margin-bottom:1rem}
.sec-sub{font-size:1rem;color:var(--muted);max-width:580px;line-height:1.7;margin-bottom:3rem}

/* PILLARS */
.pillars{background:var(--white)}
.pillar-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden}
.pillar-card{background:var(--white);padding:2.25rem 2rem}
.pillar-num{font-family:"Playfair Display",serif;font-size:2.5rem;color:rgba(201,150,42,.18);line-height:1;margin-bottom:.25rem}
.pillar-title{font-size:1.05rem;font-weight:600;color:var(--navy);margin-bottom:.5rem}
.pillar-desc{font-size:14px;color:var(--muted);line-height:1.65}

/* NEWS GRID */
.news-section{background:var(--cream)}
.news-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem}
.news-card{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:1.5rem;text-decoration:none;color:inherit;display:flex;flex-direction:column;gap:.75rem;transition:.2s;cursor:pointer}
.news-card:hover{border-color:var(--border-strong);box-shadow:0 4px 20px rgba(0,0,0,.07)}
.news-tag{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--gold)}
.news-title{font-size:15px;font-weight:500;color:var(--navy);line-height:1.4;flex:1}
.news-date{font-size:12.5px;color:var(--light)}

/* DARK SPLIT */
.dark-split{background:var(--navy);color:#fff;padding:5rem 2.5rem}
.vm-grid{display:grid;grid-template-columns:1fr 1fr;gap:2rem;margin-top:3rem}
.vm-card{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:var(--rl);padding:2rem}
.vm-label{font-size:11px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--gold-light);margin-bottom:.75rem}
.vm-card p{color:rgba(255,255,255,.75);font-size:15px;line-height:1.7}

/* BOARD */
.board-section{background:var(--white)}
.board-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.board-card{display:flex;align-items:center;gap:14px;padding:1.25rem;border:1px solid var(--border);border-radius:var(--rl)}
.board-avatar{width:52px;height:52px;border-radius:50%;background:var(--navy);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;color:var(--gold-light);flex-shrink:0;overflow:hidden}
.board-avatar img{width:100%;height:100%;object-fit:cover}
.board-name{font-size:14.5px;font-weight:600;color:var(--navy);line-height:1.3}
.board-role{font-size:12px;color:var(--muted);line-height:1.4;margin-top:2px}
.board-featured{grid-column:1/-1;display:flex;align-items:center;gap:20px;padding:1.75rem;background:var(--gold-pale);border:1px solid rgba(201,150,42,.25);border-radius:var(--rl)}
.board-featured .board-avatar{width:64px;height:64px;font-size:17px}
.board-featured .board-name{font-size:17px}

/* CTA */
.cta{background:var(--navy);color:#fff;padding:4.5rem 2.5rem;text-align:center}
.cta h2{font-family:"Playfair Display",serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:400;margin-bottom:.75rem}
.cta p{color:rgba(255,255,255,.68);margin-bottom:2rem;font-size:15px;max-width:480px;margin-left:auto;margin-right:auto}

/* UPDATES */
.updates-section{background:var(--cream);padding:4rem 2.5rem}
.update-item{background:var(--white);border:1px solid var(--border);border-radius:var(--rl);padding:1.75rem 2rem;margin-bottom:1.25rem}
.update-meta{display:flex;gap:12px;align-items:center;margin-bottom:.75rem}
.update-cat{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);background:var(--gold-pale);padding:3px 10px;border-radius:20px}
.update-date{font-size:12.5px;color:var(--light)}
.update-title{font-size:1.1rem;font-weight:600;color:var(--navy);margin-bottom:.5rem}
.update-body{font-size:14.5px;color:var(--muted);line-height:1.7;white-space:pre-wrap}
.photo-grid-1 img{width:100%;max-height:420px;object-fit:cover;border-radius:var(--r);margin-top:1rem;cursor:zoom-in}
.photo-grid-multi{display:grid;gap:6px;margin-top:1rem}
.photo-grid-2{grid-template-columns:1fr 1fr}
.photo-grid-3{grid-template-columns:1fr 1fr 1fr}
.photo-grid-many{grid-template-columns:repeat(auto-fill,minmax(180px,1fr))}
.photo-grid-multi img{width:100%;aspect-ratio:1;object-fit:cover;border-radius:var(--r);cursor:zoom-in}
.empty-state{text-align:center;padding:3rem;color:var(--muted);font-size:15px}
.loading{opacity:.5}

/* LIGHTBOX */
.lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:9999;align-items:center;justify-content:center;padding:2rem}
.lightbox.open{display:flex}
.lightbox img{max-width:100%;max-height:90vh;object-fit:contain;border-radius:var(--r)}
.lightbox-close{position:absolute;top:1rem;right:1.5rem;color:#fff;font-size:2rem;cursor:pointer;background:none;border:none;line-height:1}

/* FOOTER */
footer{background:#060f1a;color:rgba(255,255,255,.5);padding:3rem 2.5rem}
.footer-inner{max-width:900px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
.footer-brand{color:#fff;font-weight:500;font-size:14px}
.footer-links{display:flex;gap:1.5rem;list-style:none}
.footer-links a{color:rgba(255,255,255,.5);text-decoration:none;font-size:12.5px}
.footer-links a:hover{color:rgba(255,255,255,.8)}

@media(max-width:700px){
  nav{padding:0 1.25rem}
  .nav-links{display:none}
  section,.hero,.dark-split,.cta,.updates-section{padding-left:1.25rem;padding-right:1.25rem}
  .stats-inner,.pillar-grid,.news-grid,.vm-grid,.board-grid{grid-template-columns:1fr}
  .board-featured{flex-direction:column;text-align:center}
  .footer-inner{flex-direction:column}
}

/* COLLABORATE */
.collab-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem}
.collab-card{background:var(--cream);border:1px solid var(--border);border-radius:var(--rl);padding:2rem;display:flex;flex-direction:column;gap:.75rem;transition:.2s}
.collab-card:hover{border-color:var(--green);box-shadow:0 4px 24px rgba(46,125,82,.1)}
.collab-card-wide{grid-column:1/-1}
.collab-icon{width:52px;height:52px;border-radius:var(--rl);display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0}
.collab-title{font-size:1.1rem;font-weight:600;color:var(--navy)}
.collab-sub{font-size:13px;font-weight:500;color:var(--green);text-transform:uppercase;letter-spacing:.06em}
.collab-body{font-size:14.5px;color:var(--muted);line-height:1.65;flex:1}
.collab-btn{display:inline-block;margin-top:.5rem;padding:9px 20px;background:var(--white);border:1.5px solid var(--green);color:var(--green);border-radius:var(--r);font-size:13.5px;font-weight:600;text-decoration:none;transition:.15s}
.collab-btn:hover{background:var(--green);color:#fff}
@media(max-width:700px){.collab-grid{grid-template-columns:1fr}.collab-card-wide{grid-column:1}}
</style>
</head>
<body>

<nav>
  <a class="nav-logo" href="#" onclick="showPage('home');return false;">
    <img src="data:image/png;base64," alt="FAHPi">
    <div class="nav-logo-text">FAHPi<span>Filipino Australian Health Professionals</span></div>
  </a>
  <ul class="nav-links">
    <li><a href="#" id="nav-home" onclick="showPage('home');return false;">Home</a></li>
    <li><a href="#" id="nav-about" onclick="showPage('about');return false;">Who we are</a></li>
    <li><a href="#" id="nav-updates" onclick="showPage('updates');return false;">Updates</a></li>
    <li><a href="#">Medical corner</a></li>
    <li><a id="nav-collaborate" onclick="showPage('collaborate');return false;">Collaborate</a></li>
    <li><a href="#" class="nav-cta">Join FAHPi</a></li>
  </ul>
</nav>

<!-- HOME -->
<div id="page-home" class="page active">
  <div class="hero">
    <div class="hero-stripe"></div>
    <div class="hero-inner">
      <div class="eyebrow">Filipino Australian Health Professionals Inc.</div>
      <h1>Advancing health,<br><em>bridging communities</em></h1>
      <p class="hero-lead">FAHPi supports Filipino Australian health professionals practising across Canberra and the ACT — through professional development, advocacy, and a shared commitment to health equity.</p>
      <div class="hero-actions">
        <a href="#" class="btn btn-gold">Join FAHPi</a>
        <a href="#" class="btn btn-outline" onclick="showPage('about');return false;">Who we are</a>
      </div>
    </div>
  </div>

  <div class="stats-bar">
    <div class="stats-inner">
      <div class="stat-item"><div class="stat-num">2017</div><div class="stat-label">Founded</div></div>
      <div class="stat-item"><div class="stat-num">ACT</div><div class="stat-label">Based in Canberra</div></div>
      <div class="stat-item"><div class="stat-num">9</div><div class="stat-label">Board members</div></div>
      <div class="stat-item"><div class="stat-num">4</div><div class="stat-label">Pillars of purpose</div></div>
    </div>
  </div>

  <section class="pillars">
    <div class="inner">
      <div class="sec-eye">Our purpose</div>
      <h2 class="sec-head">Four pillars that guide our work</h2>
      <p class="sec-sub">Everything FAHPi does flows from four interconnected areas of focus, designed to support members and serve the wider community.</p>
      <div class="pillar-grid">
        <div class="pillar-card"><div class="pillar-num">01</div><div class="pillar-title">Policy</div><p class="pillar-desc">Advocating for policies that reflect the needs of Filipino Australian health professionals and the communities they serve, grounded in equity and social justice.</p></div>
        <div class="pillar-card"><div class="pillar-num">02</div><div class="pillar-title">Research &amp; implementation</div><p class="pillar-desc">Generating evidence and translating it into practice — supporting a culture of inquiry and continuous improvement across health disciplines.</p></div>
        <div class="pillar-card"><div class="pillar-num">03</div><div class="pillar-title">Advancement, development &amp; philanthropy</div><p class="pillar-desc">Investing in the professional growth of members and giving back to the community through education, mentorship, and charitable initiatives.</p></div>
        <div class="pillar-card"><div class="pillar-num">04</div><div class="pillar-title">Services, support &amp; outreach</div><p class="pillar-desc">Connecting members with practical support, and reaching into the wider Filipino Australian community with health education and outreach programs.</p></div>
      </div>
    </div>
  </section>

  <section class="news-section">
    <div class="inner">
      <div class="sec-eye">Latest from FAHPi</div>
      <h2 class="sec-head">News &amp; updates</h2>
      <p class="sec-sub">Stay across the latest from our community, our members, and the broader Filipino Australian health sector.</p>
      <div id="home-news" class="news-grid"></div>
    </div>
  </section>

  <div class="dark-split">
    <div class="inner">
      <div class="sec-eye" style="color:var(--gold-light)">Our direction</div>
      <h2 class="sec-head" style="color:#fff">Vision &amp; mission</h2>
      <div class="vm-grid">
        <div class="vm-card"><div class="vm-label">Vision</div><p>Strong Filipino Australian health professionals supporting a healthy nation in harmony with the ecosystem.</p></div>
        <div class="vm-card"><div class="vm-label">Mission</div><p>To be the prime Filipino Australian health-related professional organisation — representing advocacy, policies, and professional development to aid in the achievement of health equity and equality locally and globally.</p></div>
      </div>
    </div>
  </div>

  <div class="cta">
    <h2>Be part of the community</h2>
    <p>Join a credible and growing network of Filipino Australian health professionals across the ACT region.</p>
    <a href="#" class="btn btn-gold">Register as a member</a>
  </div>
</div>

<!-- WHO WE ARE -->
<div id="page-about" class="page">
  <div class="hero">
    <div class="hero-stripe"></div>
    <div class="hero-inner">
      <div class="eyebrow">About FAHPi</div>
      <h1>Who <em>we are</em></h1>
      <p class="hero-lead">A group of Filipino Australian health professionals committed to the continuous development and enrichment of our respective disciplines — and to an egalitarian society built on social justice and the social determinants of health.</p>
    </div>
  </div>

  <section class="pillars">
    <div class="inner">
      <div class="sec-eye">Our direction</div>
      <h2 class="sec-head">Vision &amp; mission</h2>
      <div class="vm-grid" style="margin-top:0">
        <div style="background:var(--gold-pale);border:1px solid rgba(201,150,42,.22);border-radius:var(--rl);padding:2rem">
          <div class="sec-eye">Vision</div>
          <p style="color:var(--navy);line-height:1.7">Strong Filipino Australian health professionals supporting a healthy nation in harmony with the ecosystem.</p>
        </div>
        <div style="background:#f0f4fb;border:1px solid rgba(21,53,87,.1);border-radius:var(--rl);padding:2rem">
          <div class="sec-eye">Mission</div>
          <p style="color:var(--navy);line-height:1.7">To be the prime Filipino Australian health-related professional organisation — representing advocacy, policy, and professional development to achieve health equity and equality locally and globally.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="board-section">
    <div class="inner">
      <div class="sec-eye">Leadership</div>
      <h2 class="sec-head">Board of directors</h2>
      <p class="sec-sub" style="margin-bottom:2rem">FAHPi is led by a dedicated board of health professionals who give their time to advance the organisation's mission.</p>
      <div class="board-grid">
        <div class="board-featured">
          <div class="board-avatar"><img src="https://fahpi.org.au/user/images/g5_audacity/fahpi/board/board-mon.png" alt="MS" style="width:100%;height:100%;object-fit:cover"></div>
          <div><div class="board-name">Dr Mon Seastres</div><div class="board-role">Executive Director</div></div>
        </div>
        <div class="board-card"><div class="board-avatar"><img src="https://fahpi.org.au/user/images/g5_audacity/fahpi/board/board-roel.png" alt="RC" style="width:100%;height:100%;object-fit:cover"></div><div><div class="board-name">Roel Castillo</div><div class="board-role">Deputy Director · Advancement, Research &amp; Policy</div></div></div>
        <div class="board-card"><div class="board-avatar"><img src="https://fahpi.org.au/user/images/g5_audacity/fahpi/board/board-andrea.png" alt="AD" style="width:100%;height:100%;object-fit:cover"></div><div><div class="board-name">Andrea Raceli David</div><div class="board-role">Director of Events</div></div></div>
        <div class="board-card"><div class="board-avatar"><img src="https://fahpi.org.au/user/images/g5_audacity/fahpi/board/board-amor.png" alt="AS" style="width:100%;height:100%;object-fit:cover"></div><div><div class="board-name">Amor Dimaano Seastres</div><div class="board-role">Director of Planning</div></div></div>
        <div class="board-card"><div class="board-avatar"><img src="https://fahpi.org.au/user/images/g5_audacity/fahpi/board/board-susan.png" alt="SS" style="width:100%;height:100%;object-fit:cover"></div><div><div class="board-name">Dr Susan Leonera Salazar</div><div class="board-role">Director of Medical Program</div></div></div>
        <div class="board-card"><div class="board-avatar"><img src="https://fahpi.org.au/user/images/g5_audacity/fahpi/board/board-chari.png" alt="CM" style="width:100%;height:100%;object-fit:cover"></div><div><div class="board-name">Chari Mercado</div><div class="board-role">Director of Finance</div></div></div>
        <div class="board-card"><div class="board-avatar"><img src="https://fahpi.org.au/user/images/g5_audacity/fahpi/board/board-dj.png" alt="DC" style="width:100%;height:100%;object-fit:cover"></div><div><div class="board-name">Dorothea Jane Camangan</div><div class="board-role">Director of Communications</div></div></div>
        <div class="board-card"><div class="board-avatar"><img src="https://fahpi.org.au/user/images/g5_audacity/fahpi/board/board-emil.png" alt="ET" style="width:100%;height:100%;object-fit:cover"></div><div><div class="board-name">Emil Terbio</div><div class="board-role">Director of Membership</div></div></div>
        <div class="board-card"><div class="board-avatar"><img src="https://fahpi.org.au/user/images/g5_audacity/fahpi/board/board-michael.jpg" alt="MC" style="width:100%;height:100%;object-fit:cover"></div><div><div class="board-name">Michael Calizo</div><div class="board-role">Director of Digital Health &amp; AI</div></div></div>
      </div>
    </div>
  </section>

  <div class="cta">
    <h2>Ready to be counted?</h2>
    <p>Help us build a credible database that serves the future interests of the Filipino Australian health community.</p>
    <a href="#" class="btn btn-gold">Join FAHPi today</a>
  </div>
</div>

<!-- UPDATES -->
<div id="page-updates" class="page">
  <div class="hero">
    <div class="hero-stripe"></div>
    <div class="hero-inner">
      <div class="eyebrow">Latest from FAHPi</div>
      <h1>News &amp; <em>updates</em></h1>
      <p class="hero-lead">Stories, announcements, and news from our community and members.</p>
    </div>
  </div>
  <div class="updates-section">
    <div class="inner">
      <div id="updates-list"></div>
    </div>
  </div>
</div>

<!-- LIGHTBOX -->

<!-- COLLABORATE -->
<div id="page-collaborate" class="page">
  <div class="hero" style="background:linear-gradient(135deg,var(--navy) 0%,var(--green-mid) 100%)">
    <div class="hero-stripe"></div>
    <div class="hero-inner">
      <div class="eyebrow">Work with us</div>
      <h1>Collaborate <em>with us</em></h1>
      <p class="hero-lead">Together we are stronger! We believe that for every goal achieved, no matter how big or small, a collective effort is behind it. We look forward to working with you!</p>
    </div>
  </div>

  <section style="background:var(--white);padding:5rem 2.5rem">
    <div class="inner">
      <div class="collab-grid">

        <div class="collab-card">
          <div class="collab-icon" style="background:var(--green-pale);color:var(--green)">&#x1F91D;</div>
          <h3 class="collab-title">Volunteer</h3>
          <p class="collab-sub">Do you have some spare time?</p>
          <p class="collab-body">We welcome retired and current health professionals who can join us through volunteering into one of our charitable and fun activities!</p>
          <a href="mailto:fahpinc@gmail.com" class="collab-btn">Get involved</a>
        </div>

        <div class="collab-card">
          <div class="collab-icon" style="background:#f0f4fb;color:var(--navy)">&#x1F4E2;</div>
          <h3 class="collab-title">Advertise</h3>
          <p class="collab-sub">Do you have a trade or profession to advertise?</p>
          <p class="collab-body">We welcome corporate partners and professionals aligned with our health advocacies to advertise your product or service on our site. Terms and conditions apply.</p>
          <a href="mailto:fahpinc@gmail.com" class="collab-btn">Enquire now</a>
        </div>

        <div class="collab-card">
          <div class="collab-icon" style="background:var(--gold-pale);color:var(--gold)">&#x2B50;</div>
          <h3 class="collab-title">Sponsorship</h3>
          <p class="collab-sub">Be a sponsor!</p>
          <p class="collab-body">Your company or you as an individual can help make our activities and events sustainable by becoming a sponsor. We look forward to hearing from you!</p>
          <a href="mailto:fahpinc@gmail.com" class="collab-btn">Become a sponsor</a>
        </div>

        <div class="collab-card">
          <div class="collab-icon" style="background:var(--green-pale);color:var(--green)">&#x2764;&#xFE0F;</div>
          <h3 class="collab-title">Donate</h3>
          <p class="collab-sub">Donate for a good cause.</p>
          <p class="collab-body">We are a not-for-profit association that always looks for ways to support and reach out to those who need it most in the context of Health. Your donation will be greatly appreciated!</p>
          <a href="mailto:fahpinc@gmail.com" class="collab-btn">Make a donation</a>
        </div>

        <div class="collab-card collab-card-wide">
          <div class="collab-icon" style="background:#f0f4fb;color:var(--navy)">&#x1F4EC;</div>
          <h3 class="collab-title">Suggestion box</h3>
          <p class="collab-sub">Have an idea or feedback?</p>
          <p class="collab-body">We love hearing from our community. Reach out to us with your suggestions, ideas, or general enquiries and we will get back to you as soon as possible.</p>
          <a href="mailto:fahpinc@gmail.com" class="collab-btn">fahpinc@gmail.com</a>
        </div>

      </div>
    </div>
  </section>

  <div style="background:var(--green-mid);color:#fff;padding:4.5rem 2.5rem;text-align:center">
    <div class="inner">
      <h2 style="font-family:'Playfair Display',serif;font-size:clamp(1.6rem,3vw,2.2rem);font-weight:400;margin-bottom:.75rem">Get in touch</h2>
      <p style="color:rgba(255,255,255,.75);margin-bottom:.5rem;font-size:15px">&#x1F4CD; Canberra ACT, Australia</p>
      <p style="color:rgba(255,255,255,.75);margin-bottom:.5rem;font-size:15px">&#x2709;&#xFE0F; <a href="mailto:fahpinc@gmail.com" style="color:var(--gold-light)">fahpinc@gmail.com</a></p>
      <p style="color:rgba(255,255,255,.75);margin-bottom:2rem;font-size:15px">&#x1F4CB; ABN 71 370 519 961</p>
      <a href="mailto:fahpinc@gmail.com" class="btn btn-gold">Contact us</a>
    </div>
  </div>
</div>

<div class="lightbox" id="lightbox" onclick="this.classList.remove('open')">
  <button class="lightbox-close">&#x2715;</button>
  <img id="lightbox-img" src="" alt="">
</div>

<footer>
  <div class="footer-inner">
    <div>
      <div class="footer-brand">Filipino Australian Health Professionals Inc.</div>
      <div style="margin-top:4px;font-size:12.5px">ABN 71 370 519 961 &middot; Based in Canberra, ACT</div>
    </div>
    <ul class="footer-links">
      <li><a href="https://www.facebook.com/groups/144269106102315" target="_blank">Facebook</a></li>
      <li><a href="https://www.instagram.com/fahpi_cbr/" target="_blank">Instagram</a></li>
      <li><a href="https://www.youtube.com/channel/UChY_FNUT2nMKgGHc20WpFLQ" target="_blank">YouTube</a></li>
      <li><a href="#">Collaborate with us</a></li>
    </ul>
    <div style="font-size:12.5px">&copy; 2017&ndash;2026 FAHPi</div>
  </div>
</footer>

<script>
// ── Config ───────────────────────────────────────────────
var BIN_ID  = "6a4b77bada38895dfe343334";
var API_KEY = "$2a$10$dxh/R62PmxmWxujp3i7yzeNtk69aJsz7/eB25ielkpEy3sStY.3H2";
var API_URL = "https://api.jsonbin.io/v3/b/" + BIN_ID;

var STATIC = [
  {category:'News', title:'Philippine Independence Day flag raising for Dr Jose Rizal', date:'12 June 2026'},
  {category:'News', title:'Eighty years on: The Filipino hands that help hold Australia together', date:'5 May 2026'},
  {category:'Medical corner', title:'World Cancer Day — prevention, detection, and care', date:'4 February 2024'},
  {category:'One Health', title:'FAHPi as a strong advocate of the One Health approach', date:'Ongoing'},
  {category:'Global health', title:'WHO warns on Monkeypox', date:'14 June 2022'},
  {category:'Events', title:'The Philippine Embassy and FAHPi: raising the profile of Filipino health professionals', date:'2021'},
];

// ── Page switching ────────────────────────────────────────
function showPage(id) {
  var pages = document.querySelectorAll('.page');
  for (var i = 0; i < pages.length; i++) pages[i].classList.remove('active');
  var pg = document.getElementById('page-' + id);
  if (pg) pg.classList.add('active');

  var links = document.querySelectorAll('.nav-links a[id]');
  for (var i = 0; i < links.length; i++) links[i].classList.remove('active');
  var lnk = document.getElementById('nav-' + id);
  if (lnk) lnk.classList.add('active');

  window.scrollTo(0, 0);
  history.replaceState(null, '', '#' + id);

  if (id === 'home') loadHomeNews();
  if (id === 'updates') loadUpdates();
  return false;
}

// ── API ───────────────────────────────────────────────────
function fetchPosts(cb) {
  var xhr = new XMLHttpRequest();
  xhr.open('GET', API_URL + '?meta=false');
  xhr.setRequestHeader('X-Master-Key', API_KEY);
  xhr.onload = function() {
    try { cb(JSON.parse(xhr.responseText)); }
    catch(e) { cb([]); }
  };
  xhr.onerror = function() { cb([]); };
  xhr.send();
}

// ── Home news grid ────────────────────────────────────────
function loadHomeNews() {
  var el = document.getElementById('home-news');
  if (!el) return;
  el.innerHTML = '';
  fetchPosts(function(posts) {
    var items = [];
    for (var i = 0; i < Math.min(posts.length, 3); i++) {
      items.push({category: posts[i].category, title: posts[i].title, date: posts[i].date});
    }
    for (var i = 0; i < STATIC.length && items.length < 6; i++) items.push(STATIC[i]);
    var html = '';
    for (var i = 0; i < items.length; i++) {
      html += '<a class="news-card" href="#" onclick="showPage(\'updates\');return false;">'
            + '<div class="news-tag">' + esc(items[i].category) + '</div>'
            + '<div class="news-title">' + esc(items[i].title) + '</div>'
            + '<div class="news-date">' + esc(items[i].date) + '</div>'
            + '</a>';
    }
    el.innerHTML = html;
  });
}

// ── Updates list ──────────────────────────────────────────
function loadUpdates() {
  var el = document.getElementById('updates-list');
  if (!el) return;
  el.innerHTML = '<div class="empty-state loading">Loading...</div>';
  fetchPosts(function(posts) {
    if (!posts.length) {
      el.innerHTML = '<div class="empty-state">No updates yet — check back soon.</div>';
      return;
    }
    var html = '';
    for (var i = 0; i < posts.length; i++) {
      var p = posts[i];
      html += '<div class="update-item">'
            + '<div class="update-meta"><span class="update-cat">' + esc(p.category) + '</span><span class="update-date">' + esc(p.date) + '</span></div>'
            + '<div class="update-title">' + esc(p.title) + '</div>'
            + '<div class="update-body">' + esc(p.body) + '</div>'
            + photoHtml(p.photos)
            + '</div>';
    }
    el.innerHTML = html;
  });
}

// ── Photos ────────────────────────────────────────────────
function photoHtml(photos) {
  if (!photos || !photos.length) return '';
  if (photos.length === 1) {
    return '<div class="photo-grid-1"><img src="' + photos[0] + '" alt="" onclick="lightbox(this.src)"></div>';
  }
  var cls = photos.length === 2 ? 'photo-grid-2' : photos.length === 3 ? 'photo-grid-3' : 'photo-grid-many';
  var out = '<div class="photo-grid-multi ' + cls + '">';
  for (var i = 0; i < photos.length; i++) {
    out += '<img src="' + photos[i] + '" alt="" onclick="lightbox(this.src)">';
  }
  return out + '</div>';
}

function lightbox(src) {
  document.getElementById('lightbox-img').src = src;
  document.getElementById('lightbox').classList.add('open');
}

// ── Escape HTML ───────────────────────────────────────────
function esc(str) {
  if (!str) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

// ── Boot ──────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function() {
  loadHomeNews();
  loadUpdates();
  var hash = window.location.hash.replace('#', '');
  if (hash && document.getElementById('page-' + hash)) {
    showPage(hash);
  } else {
    document.getElementById('nav-home').classList.add('active');
  }
});
</script>
</body>
</html>
